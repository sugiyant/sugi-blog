---
import { getAllPosts } from '../../lib/notion/posts';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = await getAllPosts();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main { width: 960px; margin: 0 auto; padding: 1rem; }
      ul { display: flex; flex-wrap: wrap; gap: 2rem; list-style: none; padding: 0; }
      ul li { width: calc(50% - 1rem); }
      ul li:first-child { width: 100%; text-align: center; margin-bottom: 1rem; }
      .title { margin: 0; color: rgb(var(--black)); }
      .date { color: rgb(var(--gray)); }
      a { text-decoration: none; }
      a:hover .title { color: rgb(var(--accent)); }
      @media (max-width: 720px) {
        ul li { width: 100%; text-align: center; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        {posts.length === 0 ? (
          <p>Belum ada artikel.</p>
        ) : (
          <ul>
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`}>
                  <h4 class="title">{post.title}</h4>
                  <p class="date"><FormattedDate date={post.date} /></p>
                  {post.excerpt && <p>{post.excerpt}</p>}
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>
